# ========================================================
#  PLANTILLA DE VARIABLES DE ENTORNO
#  Copiar este archivo a ".env" y completar los valores.
#  NUNCA subir ".env" al repositorio (ya está en .gitignore).
# ========================================================

# --- Entorno de Flask ---
FLASK_ENV=development
FLASK_DEBUG=1

# Clave secreta para sesiones y CSRF.
# Generar una real con:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-esta-clave-en-produccion

# --- Base de datos PostgreSQL 18 ---
# Formato: postgresql+psycopg://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE
DATABASE_URL=postgresql+psycopg://postgres:TU_PASSWORD@localhost:5432/reservas_saas

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery (tareas async/programadas) ---
# En desarrollo dejá CELERY_EAGER=true (las tareas corren sincrónicamente,
# sin Redis). En producción: CELERY_EAGER=false + Redis + worker + beat.
CELERY_EAGER=true
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Pasarela de pago: Mercado Pago (opcional) ---
# Sin token, el checkout funciona en modo simulación (desarrollo).
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
SITE_URL=http://127.0.0.1:5000

# --- WhatsApp Cloud API (opcional; sin esto, bandeja dev) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v21.0
