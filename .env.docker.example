# ===========================================================================
#  Variables para el stack Docker (copiar a .env.docker y completar).
#  Los hosts 'db' y 'redis' son los nombres de servicio de docker-compose.
# ===========================================================================

FLASK_ENV=production
FLASK_DEBUG=0

# Generar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-esta-clave

# --- Postgres (deben coincidir con el servicio db) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reservas_saas
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/reservas_saas

# --- Redis / Celery (async real en producción) ---
REDIS_URL=redis://redis:6379/0
CELERY_EAGER=false
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- URL pública (back_urls/webhooks de Mercado Pago) ---
SITE_URL=http://localhost:8000

# --- Mercado Pago (opcional) ---
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# --- Email (opcional; sin esto, modo bandeja dev) ---
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=Draaier <no-reply@reservas.local>
